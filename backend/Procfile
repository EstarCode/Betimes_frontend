web: gunicorn config.wsgi:application --bind 0.0.0.0:$PORT --workers 4 --threads 2 --timeout 120 --max-requests 1000 --max-requests-jitter 50 --access-logfile - --error-logfile -
worker: celery -A config worker --loglevel=info --concurrency=4 --max-tasks-per-child=1000
beat: celery -A config beat --loglevel=info
