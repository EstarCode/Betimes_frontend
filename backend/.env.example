# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for local development - no setup required)
# For production PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/betimes
DATABASE_URL=sqlite:///db.sqlite3

# Redis (for Celery async tasks)
REDIS_URL=redis://localhost:6379/0

# Celery (for async file processing)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# File Upload Settings (10GB default - enterprise level)
MAX_UPLOAD_SIZE=10737418240
ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,xlsx,pptx

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Ghostscript Path (for PDF compression)
# Windows: C:\Program Files\gs\gs10.02.1\bin\gswin64c.exe
# Linux/Mac: /usr/bin/gs
GHOSTSCRIPT_PATH=/usr/bin/gs

# LibreOffice Path (for document conversion)
# Windows: C:\Program Files\LibreOffice\program\soffice.exe
# Linux/Mac: /usr/bin/soffice
LIBREOFFICE_PATH=/usr/bin/soffice
