# Production Environment Variables
# Copy this file to .env and fill in your actual values

# Django Settings
SECRET_KEY=your-secret-key-here-generate-with-django
DEBUG=False
ALLOWED_HOSTS=betimes.onrender.com,.onrender.com
CSRF_TRUSTED_ORIGINS=https://betimes.onrender.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Redis
REDIS_URL=redis://username:password@host:6379/0
USE_REDIS_CACHE=True

# Celery
CELERY_BROKER_URL=redis://username:password@host:6379/0
CELERY_RESULT_BACKEND=redis://username:password@host:6379/0

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=15  # minutes
JWT_REFRESH_TOKEN_LIFETIME=10080  # 7 days in minutes

# CORS Settings
CORS_ALLOWED_ORIGINS=https://betimes.onrender.com,http://localhost:5173

# File Upload Settings
MAX_UPLOAD_SIZE=10737418240  # 10GB
ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,xlsx,pptx

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# MFA Settings
MFA_ISSUER_NAME=Betimes Enterprise

# Ghostscript
GHOSTSCRIPT_PATH=/usr/bin/gs

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn-here

# AWS S3 (Optional - for cloud storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Testing
TESTING=False
